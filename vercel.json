{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    { "source": "/downloads", "destination": "/", "permanent": true },
    { "source": "/downloads/", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/emulator", "permanent": true }
  ],
  "rewrites": [
    { "source": "/emulator", "destination": "/emulator.html" },
    { "source": "/emulator/", "destination": "/emulator.html" }
  ]
}
