{
  "name": "chiikawa-royale",
  "version": "1.1.13",
  "description": "Chiikawa Royale - Official PC Client",
  "main": "main.js",
  "author": "Chihua Studio",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "directories": {
      "output": "C:/Users/lexca/AppData/Local/Temp/chiikawa-build-dist"
    },
    "appId": "com.chiikawaroyale.client",
    "productName": "Chiikawa Royale",
    "copyright": "Copyright © 2026 Chihua Studio",
    "win": {
      "target": "portable",
      "icon": "gamelogo.ico",
      "sign": null,
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "Chiikawa_Royale.exe",
      "requestExecutionLevel": "user"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "gamelogo.ico",
      "chiikawa-royale-logo.ico",
      "uninstall.exe"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "game",
        "filter": [
          "index.html",
          "launcher.html",
          "styles.css",
          "game.js",
          "manifest.json",
          "chiikawa-royale-logo.png",
          "hachiware-lobby.mp4",
          "uwauwa.mp3",
          "assets/**",
          "!assets/**/*.bak.*",
          "!assets/**/*_high.mp4",
          "!assets/app logo/**",
          "!assets/chiikawa-banner-animation.mp4",
          "!assets/chiikawa-banner-bg.png",
          "!assets/launcher background/agwat teaser.mp4"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
